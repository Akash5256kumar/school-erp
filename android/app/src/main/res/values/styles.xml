<resources>

    <!--
        SplashTheme is applied to MainActivity in AndroidManifest.xml.
        The window shows launch_background (logo on white) INSTANTLY — before
        any Java/Kotlin code runs — so the user never sees a black screen.
    -->
    <style name="SplashTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!--
        AppTheme is switched to in MainActivity.onCreate() before React renders.
        It ALSO uses launch_background so the logo remains visible across the
        theme switch — no flash, no gap — until React Native draws its first frame.
    -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

</resources>
